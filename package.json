{
  "name": "dwv-vue",
  "version": "0.11.0-beta.0",
  "description": "Medical viewer using DWV (DICOM Web Viewer) and Vue.js.",
  "author": "ivmartel",
  "license": "GPL-3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build-trunk": "vite build --mode development --base /dwv-vue/demo/trunk",
    "build-stable": "vite build --mode production --base /dwv-vue/demo/stable",
    "preview": "vite preview",
    "test": "vitest",
    "test-ci": "vitest run --coverage",
    "lint": "eslint src/**/*.{js,vue}"
  },
  "dependencies": {
    "dwv": "0.36.3",
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "canvas": "^3.2.3",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "vite": "^8.0.16",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^10.4.1",
    "vuetify": "^4.1.2"
  },
  "packageManager": "yarn@4.12.0"
}
